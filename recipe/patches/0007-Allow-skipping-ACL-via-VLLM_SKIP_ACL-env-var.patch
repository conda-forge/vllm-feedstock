From 34e636261363d942a1fc9a4efb1e49b6e906db06 Mon Sep 17 00:00:00 2001
From: "Uwe L. Korn" <uwe.korn@quantco.com>
Date: Thu, 25 Jun 2026 10:32:25 +0200
Subject: [PATCH 7/9] Allow skipping ACL via VLLM_SKIP_ACL env var

---
 cmake/cpu_extension.cmake | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/cmake/cpu_extension.cmake b/cmake/cpu_extension.cmake
index 196dd28..ede0e3d 100644
--- a/cmake/cpu_extension.cmake
+++ b/cmake/cpu_extension.cmake
@@ -241,6 +241,8 @@ if (ENABLE_X86_ISA OR (ASIMD_FOUND AND NOT APPLE_SILICON_FOUND) OR POWER9_FOUND
             set(NPROC 4)
         endif()
 
+        # Allow disabling ACL (e.g. in conda-forge where it is not packaged)
+        if(NOT DEFINED ENV{VLLM_SKIP_ACL})
         # Fetch and populate ACL
         if(DEFINED ENV{ACL_ROOT_DIR} AND IS_DIRECTORY "$ENV{ACL_ROOT_DIR}")
             message(STATUS "Using ACL from specified source directory: $ENV{ACL_ROOT_DIR}")
@@ -292,6 +294,9 @@ if (ENABLE_X86_ISA OR (ASIMD_FOUND AND NOT APPLE_SILICON_FOUND) OR POWER9_FOUND
         # VLLM/oneDNN settings for ACL
         set(ONEDNN_AARCH64_USE_ACL ON CACHE BOOL "" FORCE)
         add_compile_definitions(VLLM_USE_ACL)
+        else()
+            message(STATUS "Skipping ACL (VLLM_SKIP_ACL is set)")
+        endif()  # VLLM_SKIP_ACL
     endif()
 
     set(FETCHCONTENT_SOURCE_DIR_ONEDNN "$ENV{FETCHCONTENT_SOURCE_DIR_ONEDNN}" CACHE PATH "Path to a local oneDNN source directory.")
